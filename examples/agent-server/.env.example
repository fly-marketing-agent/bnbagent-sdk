# examples/agent-server — copy to .env and fill in your values.

# --- Wallet (required) ---
WALLET_PASSWORD=demo-password
# First run only — after keystore is written under ~/.bnbagent/wallets, drop it.
PRIVATE_KEY=0x...
# Select a specific keystore if you have several.
# WALLET_ADDRESS=0x...

# --- Network ---
NETWORK=bsc-testnet
# RPC_URL=https://data-seed-prebsc-2-s2.binance.org:8545

# --- APEX contract overrides (bsc-testnet defaults apply; only set to override) ---
# APEX_COMMERCE_ADDRESS=0x...
# APEX_ROUTER_ADDRESS=0x...
# APEX_POLICY_ADDRESS=0x...

# --- IPFS Storage via Pinata (required for deliverable upload) ---
STORAGE_PROVIDER=ipfs
STORAGE_API_KEY=your_pinata_jwt_here   # https://app.pinata.cloud → API Keys → New Key (pinJSONToIPFS)
STORAGE_GATEWAY_URL=https://gateway.pinata.cloud/ipfs/

# --- APEX agent settings ---
APEX_SERVICE_PRICE=1000000000000000000  # minimum budget in raw token units (1 token @ 18 dp)
# APEX_FUNDED_POLL_INTERVAL=30          # funded-job poll cadence (seconds)
# APEX_NEGOTIATE_RATE_LIMIT=120         # /negotiate per-IP request budget
# APEX_NEGOTIATE_RATE_WINDOW=60         # rate-limit window (seconds)
# APEX_MAX_RESPONSE_BYTES=5242880       # response_content cap (5 MB)
# APEX_MAX_METADATA_BYTES=262144        # metadata cap (256 KB)

# --- Example-only (agent metadata + port) ---
AGENT_NAME=blockchain-news
AGENT_DESCRIPTION=Blockchain news search agent
AGENT_HOST=http://localhost:8003
PORT=8003
