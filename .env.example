# =============================================================================
# bnbagent-sdk — environment variable reference
# =============================================================================
# Copy to .env and uncomment what you need. Everything below is OPTIONAL
# unless explicitly marked REQUIRED by a given module.
#
# Convention:
#   - Global (no prefix):         NETWORK, RPC_URL, PRIVATE_KEY, WALLET_*, DEBUG
#   - APEX module:                APEX_*
#   - ERC-8004 module:            ERC8004_*
#   - Storage module:             STORAGE_*
#
# Module-specific configs read their env lazily, so you only need the vars
# for the modules you actually use.
# =============================================================================


# --------------------------------------------------------------- 1. GLOBAL ---

# Network preset. Currently ships: bsc-testnet (default), bsc-mainnet (TBD).
# NETWORK=bsc-testnet

# Override the network's default RPC endpoint.
# RPC_URL=https://data-seed-prebsc-2-s2.binance.org:8545

# REQUIRED (wallet): password used to encrypt/decrypt the local keystore.
# WALLET_PASSWORD=demo-password

# First run only: raw private key. After the SDK writes the encrypted keystore
# under ~/.bnbagent/wallets/<address>.json, remove PRIVATE_KEY — the password
# alone is enough on subsequent runs.
# PRIVATE_KEY=0x...

# Pick a specific keystore when you have several. Optional.
# WALLET_ADDRESS=0x...

# Verbose logging.
# DEBUG=false


# ----------------------------------------------------------------- 2. APEX ---
# APEX v1 = AgenticCommerce kernel + EvaluatorRouter + OptimisticPolicy.
# Addresse default to the bsc-testnet deployment; override only for custom
# deploys.

# APEX_COMMERCE_ADDRESS=0x1e677fc06ff772e81051484c8c3845fbef13986d
# APEX_ROUTER_ADDRESS=0x0c729baa3cdac6cc3fdef6a816f6bcb85ae92ed7
# APEX_POLICY_ADDRESS=0x459c3b7a46aa9dde45fbfc3b3d37bd062dbe6fb8

# Minimum job budget this provider will accept, in raw payment-token units
# (decimals fetched on-chain at startup). Returned as HTTP 402 when a job
# comes in underpriced.
# APEX_SERVICE_PRICE=1000000000000000000

# Funded-job poll loop interval in seconds (agent-server only). The agent
# scans on-chain for newly FUNDED jobs assigned to this provider every N s.
# APEX_FUNDED_POLL_INTERVAL=30

# /negotiate per-IP rate limit. Default: 120 requests per 60-second window.
# Above the limit, callers receive HTTP 429.
# APEX_NEGOTIATE_RATE_LIMIT=120
# APEX_NEGOTIATE_RATE_WINDOW=60

# Per-deliverable upload caps enforced inside submit_result. The first guards
# response_content (5 MB default), the second the metadata JSON (256 KB).
# Excess returns success=False with error_code=413.
# APEX_MAX_RESPONSE_BYTES=5242880
# APEX_MAX_METADATA_BYTES=262144


# ------------------------------------------------------------- 3. ERC-8004 ---

# ERC8004_REGISTRY_ADDRESS=0x8004A818BFB912233c491871b3d84c89A494BD9e


# -------------------------------------------------------------- 4. STORAGE ---
# Off-chain deliverable store. "local" is zero-config (writes to base_dir).
# "ipfs" talks to any Pinata-compatible pin service.

# STORAGE_PROVIDER=local              # local | ipfs
# STORAGE_LOCAL_PATH=.agent-data      # base dir when STORAGE_PROVIDER=local

# STORAGE_API_KEY=your_pinata_jwt     # required when STORAGE_PROVIDER=ipfs
# STORAGE_API_URL=                    # optional custom pin endpoint
# STORAGE_GATEWAY_URL=https://gateway.pinata.cloud/ipfs/


# --------------------------------------------------------- 5. EXAMPLES-ONLY ---
# Consumed only by scripts under examples/. Not read by the SDK itself.

# examples/agent-server:
# AGENT_NAME=blockchain-news
# AGENT_DESCRIPTION=Blockchain news search agent
# AGENT_HOST=http://localhost:8003
# PORT=8003

# examples/client (the "payer"):
# PROVIDER_ADDRESS=0x...
# PROVIDER_PRIVATE_KEY=                 # if the script should drive submit
# VOTER_PRIVATE_KEY=                    # dispute / stalemate flows

# examples/voter (whitelisted voter):
# VOTER_PRIVATE_KEY=0x...
